BANTABRO_SERVICE_ROLE=worker

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://onchain.bantah.fun
OPENROUTER_TITLE=Bant-A-Bro
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Optional: switch to ElizaOS Twitter worker (OAuth 1.0a required)
TWITTER_WORKER_PROVIDER=eliza
TWITTER_API_SECRET_KEY=
TWITTER_POLL_INTERVAL=5
TWITTER_SEARCH_ENABLE=true
TWITTER_AUTO_RESPOND_MENTIONS=true
TWITTER_AUTO_RESPOND_REPLIES=true
TWITTER_POST_ENABLE=false

# Optional: switch to TwitterAPI.io instead of X API v2
# TWITTER_PROVIDER=twitterapi_io
# TWITTERAPI_IO_KEY=
# TWITTERAPI_IO_USERNAME=
# TWITTERAPI_IO_LOGIN_COOKIES=
# TWITTERAPI_IO_PROXY=
# TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io

BANTAH_OFFCHAIN_BASE_URL=
BANTAH_ONCHAIN_BASE_URL=
BANTAH_AGENT_TOKEN_SECRET=
BANTAH_AGENT_SERVICE_ID=service:bantah-ai-agent
BANTAH_OFFCHAIN_AUDIENCE=bantah-offchain
BANTAH_ONCHAIN_AUDIENCE=bantah-onchain
BANTAH_AGENT_TOKEN_TTL_MS=900000

BANTAH_CHALLENGE_MODE=onchain_only
BANT_A_BRO_WEB_URL=https://onchain.bantah.fun
BANTABRO_DB_PATH=/data/bantabro.sqlite

# Optional trusted Bantah proxy header secret.
BANTAH_CONTEXT_HEADER_SECRET=
